{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": "."
  },
  "include": ["web/**/*.js", "web/**/*.jsx"],
  "exclude": [
    "node_modules",
    "web/node_modules",
    "web/frontend/node_modules",
    "web/frontend/dist"
  ]
}
